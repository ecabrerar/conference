<!DOCTYPE html SYSTEM "http://www.thymeleaf.org/dtd/xhtml1-strict-thymeleaf-4.dtd">

<html xmlns="http://www.w3.org/1999/xhtml" xmlns:th="http://www.thymeleaf.org">

<body>
    <div th:fragment="schedule" th:remove="tag">
        <!-- Event Schedule Start -->
        <div class="meeta-event-schedule meeta-event-schedule-2 section-padding" id="schedule">
            <div class="container">

                <!-- Section Title Start -->
                <div class="meeta-section-title-2 text-center">
                    <h2 class="main-title">Schedule at a Glance</h2>
                </div>
                <!-- Section Title End -->

                <div class="row gy-5 justify-content-between">
                <div class="col-xl-6 col-lg-6">
                <h2>Day 0: JakartaOne Community Meetup - Dominican Republic | July 16, 2026</h2>
                    <h4>Event Venue</h4>
                     <p>PUCMM,Santiago. Autopista Duarte Km 1 1/2, Santiago de los Caballeros.Dominican Republic</p>

                        <p><a href="https://maps.app.goo.gl/h5EmSTymCBUiVQ278"
                                target="_blank"><i class="fa fa-map"></i> Sede de Postgrado PUCMM, Santiago</a>
                        </p>
                      <p><i class="fa fa-clock"></i> 6:00 P.M. - 9:30 P.M.</p>


                </div>
                <div class="col-xl-6 col-lg-6">
                    <h2>Day 1: Workshops | July 17, 2026</h2>
                        <h4>Event Venue</h4>
                         <p>PUCMM,Santiago. Autopista Duarte Km 1 1/2, Santiago de los Caballeros.Dominican Republic</p>

                           <p><a href="https://maps.app.goo.gl/h5EmSTymCBUiVQ278"
                                                           target="_blank"><i class="fa fa-map"></i> Sede de Postgrado PUCMM, Santiago</a>
                          </p>
                        <p><i class="fa fa-clock"></i> 1:00 P.M. - 6:00 P.M.</p>

                        </div>
                        <div class="col-xl-6 col-lg-6">
                                   <h2>Day 2: Conference Day | July 18, 2025</h2>

                                   <h4>Event Venue</h2>
                                   <p>PUCMM,Santiago. Autopista Duarte Km 1 1/2, Santiago de los Caballeros.Dominican Republic</p>

                                   <p><a href="https://maps.app.goo.gl/y5ozh7St9nVMEYFz5"
                                                      target="_blank"><i class="fa fa-map"></i> Teatro PUCMM,Santiago</a></p>

                                              </p>
                                  <p><i class="fa fa-clock"></i> 7:30 A.M. - 6:00 P.M.</p>


                    </div>
               </div>
                <div class="row gy-5 justify-content-between">
               <div class="col text-center section-padding">
               <!-- Browse agenda-->
               <a class="btn btn-3 btn-primary" th:href="${config.layout_display_schedule_url}" href="schedule.html" target="_blank" th:if="${config.layout_display_schedule && config.layout_display_general_agenda}">Browse the event schedule</a>
                </div>
                </div>
            </div>
        </div>
        <!-- Event Schedule End -->
        <script type="module" src="js/workshops.js"></script>
        <script type="module" src="js/session.js"></script>
    </div>
</body>

</html>